{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Forge",
  "version": "0.1.0",
  "identifier": "com.chester.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Media Forge",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "theme": "Dark",
        "backgroundColor": "#1e1e2e",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
