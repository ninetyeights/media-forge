{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaForge",
  "version": "0.4.0",
  "identifier": "com.ninetyeights.mediaforge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "媒体工坊",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "theme": "Dark",
        "backgroundColor": "#1e1e2e",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4MjI4Mjc4MjFGNjBDREYKUldUZkRQWWhlSUlpU0FjTzRrVUFuVkY2ZzlWc2ttUVJjckxrV3lHUDdzNGI4aDI2TGVLSzQzdWsK",
      "endpoints": [
        "https://github.com/ninetyeights/media-forge/releases/latest/download/latest.json"
      ]
    }
  }
}
